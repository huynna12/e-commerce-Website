# ========= Django core =========
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-rotate-before-any-public-push
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ========= Production security (recommended) =========
# Enable these when you deploy behind HTTPS.
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

# If you use CSRF cookies (recommended when using session auth)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========= Frontend / CORS =========
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# If your frontend is hosted on a different origin (e.g., Render Static Site) and you want
# session-based features to work (like "recently viewed"), enable credentials + cross-site cookies.
# In production, Render uses HTTPS so this is safe to enable.
CORS_ALLOW_CREDENTIALS=0
DJANGO_CROSS_SITE_COOKIES=0

# ========= Database =========
# Local dev: keep SQLite by leaving DATABASE_URL empty (if your settings default to sqlite),
# or explicitly set it like this:
# DATABASE_URL=sqlite:///db.sqlite3
#
# Later (Postgres/RDS):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# ========= Auth (SimpleJWT) =========
# Optional: set if you override signing key; otherwise it may use DJANGO_SECRET_KEY depending on config
# JWT_SIGNING_KEY=change-me

# ========= AWS S3 (Media uploads) =========
# Later: set USE_S3=1 and fill the rest.
USE_S3=0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
# If you use CloudFront/custom domain:
AWS_S3_CUSTOM_DOMAIN=

# ========= Email (optional) =========
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ========= Observability (optional) =========
# SENTRY_DSN=